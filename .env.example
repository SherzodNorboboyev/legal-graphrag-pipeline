# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=local
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Data directories
# -----------------------------------------------------------------------------
DATA_DIR=data
RAW_DIR=data/raw
MARKDOWN_DIR=data/markdown
SAMPLE_OUTPUT_DIR=data/sample_output
CHECKPOINT_FILE=data/crawl_checkpoint.json
EMBEDDING_CACHE_PATH=data/embedding_cache.sqlite3

# -----------------------------------------------------------------------------
# Source websites
# -----------------------------------------------------------------------------
QANOON_BASE_URL=https://qanoon.om/
DECREE_BASE_URL=https://decree.om/
SCRAPE_ENGLISH=true

# -----------------------------------------------------------------------------
# Scraper behavior
# -----------------------------------------------------------------------------
USE_PLAYWRIGHT=false
MAX_PAGES=1000
REQUEST_TIMEOUT_SECONDS=30
REQUEST_RETRIES=3
THROTTLE_MIN_SECONDS=1.0
THROTTLE_MAX_SECONDS=3.5

# -----------------------------------------------------------------------------
# Neo4j
# IMPORTANT:
# Change NEO4J_PASSWORD before using this outside local development.
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me
NEO4J_DATABASE=neo4j
NEO4J_VECTOR_DIMENSIONS=384

# -----------------------------------------------------------------------------
# Embeddings
# Default provider is local SentenceTransformers.
# Set EMBEDDING_PROVIDER=openai to use OpenAI embeddings.
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=sentence_transformers
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# LLM topic extraction and answer synthesis
# Values:
#   fallback - deterministic offline fallback
#   openai   - OpenAI API
# -----------------------------------------------------------------------------
TOPIC_LLM_PROVIDER=fallback
OPENAI_CHAT_MODEL=gpt-4o-mini
TOPIC_EXTRACTION_MAX_RETRIES=2
SYNTHESIS_PROVIDER=fallback

# -----------------------------------------------------------------------------
# Chunking
# -----------------------------------------------------------------------------
CHUNK_MIN_TOKENS=500
CHUNK_MAX_TOKENS=900
CHUNK_OVERLAP_TOKENS=120

# -----------------------------------------------------------------------------
# Hybrid retrieval
# -----------------------------------------------------------------------------
HYBRID_VECTOR_WEIGHT=0.65
HYBRID_KEYWORD_WEIGHT=0.35
RERANKER_ENABLED=false
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# -----------------------------------------------------------------------------
# Topic merging
# -----------------------------------------------------------------------------
TOPIC_MERGE_SIMILARITY=0.88